// Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  OFFICER
  STUDENT
}

enum OfficerAccessRole {
  TREASURER
  PRESIDENT
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  orgId     String?
  orgRole   String?
  yearLevel String?
  officerAccessRole OfficerAccessRole?
  sectionId  String?  @db.ObjectId
  lastLoginAt DateTime?
  deactivatedAt DateTime?
  deactivationReason String?

  section          Section? @relation(fields: [sectionId], references: [id])
  transactions     Transaction[]
  installmentPlans InstallmentPlan[]
  memberCollectionSchedules CollectionSchedule[] @relation("MemberCollectionSchedules")
  loginVerificationChallenges LoginVerificationChallenge[]
  trustedDevices TrustedDevice[]
  loginEvents LoginEvent[]
  activityLogs ActivityLog[] @relation("ActivityActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FundType {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  description      String?
  amount           Float
  frequency        FundFrequency @default(PER_SEMESTER)
  required         Boolean       @default(false)
  allowInstallment Boolean       @default(false)
  maxInstallments  Int?
  archivedAt       DateTime?
  orgId            String

  transactions     Transaction[]
  installmentPlans InstallmentPlan[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum FundFrequency {
  MONTHLY
  PER_SEMESTER
  ANNUAL
  PER_EVENT
}

enum TransactionType {
  FULL_PAYMENT
  INSTALLMENT_PAYMENT
}

enum TransactionStatus {
  PAID
  PENDING
  OVERDUE
}

model Transaction {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String            @db.ObjectId
  fundTypeId      String            @db.ObjectId
  collectionPeriodId String?        @db.ObjectId
  type            TransactionType
  status          TransactionStatus @default(PAID)
  amount          Float
  dueDate         DateTime?
  paidAt          DateTime?
  note            String?
  installmentInfo String?
  deletedAt       DateTime?

  member          User              @relation(fields: [memberId], references: [id])
  fundType        FundType          @relation(fields: [fundTypeId], references: [id])
  collectionPeriod CollectionPeriod? @relation(fields: [collectionPeriodId], references: [id])

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

model InstallmentPlan {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  memberId    String       @db.ObjectId
  fundTypeId  String       @db.ObjectId
  collectionPeriodId String? @db.ObjectId
  periodLabel String?
  status      PlanStatus   @default(ACTIVE)
  deletedAt   DateTime?

  member      User         @relation(fields: [memberId], references: [id])
  fundType    FundType     @relation(fields: [fundTypeId], references: [id])
  collectionPeriod CollectionPeriod? @relation(fields: [collectionPeriodId], references: [id])
  entries     InstallmentEntry[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model InstallmentEntry {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  planId      String            @db.ObjectId
  amountDue   Float
  dueDate     DateTime
  status      TransactionStatus @default(PENDING)
  title       String?
  paidAt      DateTime?
  deletedAt   DateTime?

  plan        InstallmentPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Section {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String
  name      String
  deletedAt DateTime?

  members   User[]
  importDrafts MemberImportDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CollectionPeriod {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  schedules CollectionSchedule[]
  transactions Transaction[]
  installmentPlans InstallmentPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CollectionScheduleScope {
  ORG_DEFAULT
  MEMBER_OVERRIDE
}

model CollectionSchedule {
  id               String                  @id @default(auto()) @map("_id") @db.ObjectId
  orgId            String
  collectionPeriodId String                @db.ObjectId
  memberId         String?                 @db.ObjectId
  scope            CollectionScheduleScope @default(ORG_DEFAULT)
  name             String?
  weekdays         Int[]
  note             String?
  deletedAt        DateTime?

  collectionPeriod CollectionPeriod        @relation(fields: [collectionPeriodId], references: [id])
  member           User?                   @relation("MemberCollectionSchedules", fields: [memberId], references: [id])

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

enum LoginChallengeStatus {
  PENDING
  VERIFIED
  CONSUMED
  FAILED
  EXPIRED
}

enum LoginEventStatus {
  PASSWORD_FAILED
  OTP_SENT
  OTP_FAILED
  SUCCEEDED
  SIGNED_OUT
}

enum ActivityEntityType {
  FUND_TYPE
  TRANSACTION
  INSTALLMENT_PLAN
  INSTALLMENT_ENTRY
  SECTION
  COLLECTION_PERIOD
  COLLECTION_SCHEDULE
  MEMBER
  USER_ACCOUNT
  MEMBER_IMPORT_DRAFT
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  PAYMENT_RECORD
  INSTALLMENT_RECORD
  STATUS_CHANGE
}

model LoginVerificationChallenge {
  id                       String               @id @default(auto()) @map("_id") @db.ObjectId
  userId                   String               @db.ObjectId
  email                    String
  role                     Role
  otpRequired              Boolean              @default(true)
  status                   LoginChallengeStatus @default(PENDING)
  codeHash                 String?
  codeExpiresAt            DateTime?
  verificationTokenHash    String?
  verificationTokenExpiresAt DateTime?
  failedAttempts           Int                  @default(0)
  lastSentAt               DateTime             @default(now())
  passwordVerifiedAt       DateTime             @default(now())
  verifiedAt               DateTime?
  consumedAt               DateTime?
  fingerprintHash          String?
  deviceLabel              String?
  userAgent                String?
  platform                 String?
  language                 String?
  ipAddress                String?
  suspiciousReason         String?

  user                     User                 @relation(fields: [userId], references: [id])

  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model TrustedDevice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  tokenHash       String   @unique
  fingerprintHash String?
  label           String?
  userAgent       String?
  platform        String?
  language        String?
  ipAddress       String?
  lastSeenAt      DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?

  user            User     @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LoginEvent {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?          @db.ObjectId
  email       String
  role        Role?
  status      LoginEventStatus
  mfaRequired Boolean          @default(false)
  deviceLabel String?
  ipAddress   String?
  userAgent   String?
  platform    String?
  detail      String?

  user        User?            @relation(fields: [userId], references: [id])

  createdAt   DateTime         @default(now())
}

model ActivityLog {
  id                 String            @id @default(auto()) @map("_id") @db.ObjectId
  orgId              String
  actorUserId        String?           @db.ObjectId
  actorOfficerRole   OfficerAccessRole?
  actorNameSnapshot  String?
  actorEmailSnapshot String?
  actorOfficerRoleSnapshot OfficerAccessRole?
  entityType         ActivityEntityType
  entityId           String
  action             ActivityAction
  note               String?
  beforeSnapshot     Json?
  afterSnapshot      Json?

  actor              User?             @relation("ActivityActor", fields: [actorUserId], references: [id])

  createdAt          DateTime          @default(now())
}

enum MemberImportDraftStatus {
  INCOMPLETE
  READY
  ERROR
}

model MemberImportDraft {
  id             String                  @id @default(auto()) @map("_id") @db.ObjectId
  orgId          String
  name           String
  email          String?
  orgRole        String?
  yearLevel      String?
  sectionId      String?                 @db.ObjectId
  sourceFileName String?
  status         MemberImportDraftStatus @default(INCOMPLETE)
  issueSummary   String?
  rawData        Json?
  createdByUserId String?                @db.ObjectId

  section        Section?                @relation(fields: [sectionId], references: [id])

  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}
