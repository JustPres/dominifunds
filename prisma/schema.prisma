// Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  OFFICER
  STUDENT
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  orgId     String?
  orgRole   String?
  yearLevel String?

  transactions     Transaction[]
  installmentPlans InstallmentPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FundType {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  description      String?
  amount           Float
  frequency        FundFrequency @default(PER_SEMESTER)
  required         Boolean       @default(false)
  allowInstallment Boolean       @default(false)
  maxInstallments  Int?
  archivedAt       DateTime?
  orgId            String

  transactions     Transaction[]
  installmentPlans InstallmentPlan[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum FundFrequency {
  MONTHLY
  PER_SEMESTER
  ANNUAL
  PER_EVENT
}

enum TransactionType {
  FULL_PAYMENT
  INSTALLMENT_PAYMENT
}

enum TransactionStatus {
  PAID
  PENDING
  OVERDUE
}

model Transaction {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String            @db.ObjectId
  fundTypeId      String            @db.ObjectId
  type            TransactionType
  status          TransactionStatus @default(PAID)
  amount          Float
  dueDate         DateTime?
  note            String?
  installmentInfo String?

  member          User              @relation(fields: [memberId], references: [id])
  fundType        FundType          @relation(fields: [fundTypeId], references: [id])

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

model InstallmentPlan {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  memberId    String       @db.ObjectId
  fundTypeId  String       @db.ObjectId
  periodLabel String?
  status      PlanStatus   @default(ACTIVE)

  member      User         @relation(fields: [memberId], references: [id])
  fundType    FundType     @relation(fields: [fundTypeId], references: [id])
  entries     InstallmentEntry[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model InstallmentEntry {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  planId      String            @db.ObjectId
  amountDue   Float
  dueDate     DateTime
  status      TransactionStatus @default(PENDING)
  title       String?

  plan        InstallmentPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}
